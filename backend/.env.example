# Application settings
APP_NAME=Gym App API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# API settings
API_V1_PREFIX=/api/v1
OPENAPI_URL=/openapi.json
DOCS_URL=/docs
REDOC_URL=/redoc

# CORS settings (comma-separated for multiple origins)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# PostgreSQL settings
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=gym_app
POSTGRES_PASSWORD=gym_app_password
POSTGRES_DB=gym_app
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# MongoDB settings
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_DB=gym_app
MONGODB_AUTH_SOURCE=admin

# Redis settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL=false

# Rate limiting settings
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Logging settings
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security settings
SECRET_KEY=your-secret-key-change-in-production-must-be-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Account lockout settings
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# Email settings (SMTP)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
FROM_EMAIL=noreply@gymapp.com
FROM_NAME=Gym App
FRONTEND_URL=http://localhost:3000

# Verification token settings
VERIFICATION_TOKEN_EXPIRY_HOURS=24

# Auto-attendance settings
# Enables automatic attendance marking when exercises are logged during scheduled sessions
AUTO_ATTENDANCE_ENABLED=true
# Time tolerance in minutes for matching workouts to sessions (before/after session time)
AUTO_ATTENDANCE_TOLERANCE_MINUTES=15
